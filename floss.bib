@Article{	  FangNeufeld2009,
  author	= { Yulin Fang and Derrick Neufeld },
  title		= {Understanding Sustained Participation in Open Source
		  Software Projects},
  journal	= {Journal of Management Information Systems},
  volume	= {25},
