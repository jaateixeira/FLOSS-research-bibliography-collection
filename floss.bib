@Article{	  Goth2005,
  author	= {G. Goth},
  journal	= {IEEE Software},
  title		= {Open source business models: ready for prime time},
  year		= {2005},
  volume	= {22},
  number	= {6},
  pages		= {98-100},
  abstract	= {Open source software was ready for any enterprise by
		  putting its full corporate support behind Linux, the open
		  source ecosystem has matured into a shoulder-to-shoulder
